# ─── Environment ───────────────────────────────
# Target environment: local | dev | staging | production
TEST_ENV=local

# Override base URL (optional — defaults come from env.config.ts)
# BASE_URL=https://practicesoftwaretesting.com
# API_URL=https://practicesoftwaretesting.com/api

# ─── Test Users ────────────────────────────────
ADMIN_USER=admin@example.com
ADMIN_PASS=admin-password
STANDARD_USER=user@example.com
STANDARD_PASS=user-password
READONLY_USER=readonly@example.com
READONLY_PASS=readonly-password
