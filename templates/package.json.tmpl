{
  "name": "{{projectName}}",
  "version": "1.0.0",
  "description": "E2E test suite built with Playwright and Page Object Model architecture",
  "private": true,
  "scripts": {
    "test": "npx playwright test",
    "test:smoke": "npx playwright test --grep @smoke",
    "test:regression": "npx playwright test --grep @regression",
    "test:critical": "npx playwright test --grep @critical",
    "test:visual": "npx playwright test --project=visual",
    "test:mobile": "npx playwright test --project=mobile",
    "test:headed": "npx playwright test --headed",
    "test:debug": "npx playwright test --debug",
    "test:ui": "npx playwright test --ui",
    "test:dev": "TEST_ENV=dev npx playwright test",
    "test:staging": "TEST_ENV=staging npx playwright test",
    "report": "npx playwright show-report reports/playwright-html",
    "lint": "npx @biomejs/biome check .",
    "lint:fix": "npx @biomejs/biome check --write .",
    "format": "npx @biomejs/biome format --write .",
    "codegen": "npx playwright codegen",
    "update-snapshots": "npx playwright test --project=visual --update-snapshots"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.0",
    "@playwright/test": "^1.48.0",
    "dotenv": "^16.4.0",
    "typescript": "^5.5.0"
  }
}
